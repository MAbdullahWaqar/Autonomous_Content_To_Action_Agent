# ============================================================
# CTA Agent Backend — Environment Variables
# Copy this file to .env.local and fill in your values
# cp .env.local.example .env.local
# ============================================================

# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Model id (optional). Default is gemini-2.5-flash.
# Do NOT use gemini-2.0-flash-lite unless your project shows quota at ai.google.dev/rate-limit
# (some accounts show limit: 0 for flash-lite on free tier).
# GEMINI_MODEL=gemini-2.5-flash

# Firebase Admin SDK (required)
# Download service account JSON from Firebase Console:
# Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Optional: Web demo at /demo (Firebase JS client; same project as mobile) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Optional: real outbound webhook after simulation (demo: webhook.site / Discord) ---
# POSTs a compact JSON payload when the execution simulator + evidence step completes.
# ACTION_WEBHOOK_URL=https://webhook.site/your-unique-id
# ACTION_WEBHOOK_SECRET=optional_shared_secret_sent_as_X_CTA_Webhook_Secret
